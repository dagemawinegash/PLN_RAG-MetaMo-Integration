# Copy this file to .env and fill in the keys you plan to use.
# Only one provider is required, but you can keep both for easy switching.

# Preferred provider: "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI configuration
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini configuration
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-3-flash-preview

# Search + PLN-RAG integration
SERPER_API_KEY=your-serper-key
SERPER_API_URL=https://google.serper.dev/search
SERPER_TYPE=search
SERPER_GL=us
SERPER_HL=en
SERPER_TIMEOUT_SECONDS=25
SEARCH_TOP_K=1
SCRAPER_TIMEOUT_SECONDS=12

PLNRAG_BASE_URL=http://localhost:8001

# Session runner override (optional): e.g. session_short.py
SESSION_FILE=session_pln_integration.py
